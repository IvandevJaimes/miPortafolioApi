{
  "name": "miportafolio-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && node -e \"const fs=require('fs');const p='dist';fs.readdirSync(p,{recursive:true}).forEach(f=>{if(f.endsWith('.js')){let c=fs.readFileSync(p+'/'+f,'utf8');c=c.replace(/from '\\.\\/([^']+)\\.js'/g,\\\"from '\\.\\\\/$1'\\\");c=c.replace(/from '(\\.\\.?\\/[^']+)\\.js'/g,'\\$1');fs.writeFileSync(p+'/'+f,c)}})\"",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "mysql2": "^3.12.0",
    "resend": "^6.10.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
